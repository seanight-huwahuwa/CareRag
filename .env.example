# Azure OpenAI API設定
AZURE_OPENAI_API_KEY=your_gpt_api_key_here
AZURE_EMBEDDING_API_KEY=your_embedding_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_OPENAI_API_VERSION=2025-01-01-preview
AZURE_EMBEDDING_API_VERSION=2023-05-15
AZURE_EMBEDDING_DEPLOYMENT=text-embedding-3-small
AZURE_GPT_DEPLOYMENT=gpt-4o-mini

# ChromaDB設定
CHROMA_PERSIST_DIRECTORY=./vector_db/chroma_data

# アプリ設定
APP_TITLE=AIケアプラン作成支援システム
APP_DESCRIPTION=グループホーム向けケアプラン原案作成ツール

# スクレイパー設定
SCRAPER_BASE_URL=https://example.com
